# ==========================================================================
# RAG Application - backend configuration
# Every key is OPTIONAL. Blank keys keep the app on free local fallbacks:
#   in-memory DB, in-memory vector store, hashing embeddings, extractive answers.
# Copy to .env and fill in what you have.
# ==========================================================================

# --- Application ---
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth (REQUIRED in production; generate: python -c "import secrets; print(secrets.token_urlsafe(48))") ---
JWT_SECRET=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# --- MongoDB (blank -> in-memory database) ---
MONGODB_URI=
MONGODB_DB=rag_application

# --- Qdrant vector store (blank -> in-memory vector store) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Gemini LLM + embeddings (blank -> extractive answers, local embeddings) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# "local" (default, free) or "gemini" (neural embeddings, needs GEMINI_API_KEY)
EMBEDDING_PROVIDER=local

# --- Cohere reranker (blank -> local lexical reranker) ---
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0

# --- RAG tuning ---
CHUNK_SIZE_WORDS=200
CHUNK_OVERLAP_WORDS=40
MAX_DOCUMENT_CHARS=200000
DEFAULT_TOP_K=5
