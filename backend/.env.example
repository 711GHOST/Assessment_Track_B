# ==========================================================================
# RAG Application - backend configuration
# Every key is OPTIONAL. Blank keys keep the app on free local providers:
#   in-memory DB, in-memory vector store, and (with 'fastembed' installed)
#   local NEURAL BGE-small embeddings + a cross-encoder reranker — no API key.
# Copy to .env and fill in what you have.
# ==========================================================================

# --- Application ---
ENVIRONMENT=development
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Auth (REQUIRED in production; generate: python -c "import secrets; print(secrets.token_urlsafe(48))") ---
JWT_SECRET=
ACCESS_TOKEN_MINUTES=30
REFRESH_TOKEN_DAYS=7

# --- MongoDB (blank -> in-memory database) ---
MONGODB_URI=
MONGODB_DB=rag_application

# --- Qdrant vector store (blank -> in-memory vector store) ---
QDRANT_URL=
QDRANT_API_KEY=

# --- Embeddings ---
# auto (default): local neural BGE-small via fastembed, else hashing fallback
# Options: auto | fastembed | local (hashing) | gemini
EMBEDDING_PROVIDER=auto

# --- Reranker ---
# auto (default): local neural cross-encoder via fastembed, else lexical
# Options: auto | fastembed | local (lexical)   (Cohere key overrides these)
RERANKER_PROVIDER=auto

# --- Gemini LLM (blank -> local extractive answers) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# --- Cohere reranker (blank -> local reranker per RERANKER_PROVIDER) ---
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-english-v3.0

# --- RAG tuning ---
CHUNK_SIZE_WORDS=200
CHUNK_OVERLAP_WORDS=40
MAX_DOCUMENT_CHARS=200000
DEFAULT_TOP_K=5
